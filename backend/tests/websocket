uv run python -c '
import asyncio
import json
import websockets

WS_URL = "wss://s0.quilichini.cloud/call/in/ws"

async def main():
    async with websockets.connect(WS_URL) as ws:
        print("connected")

        await ws.send(json.dumps({
            "type": "setup",
            "callSid": "CA_TEST",
            "from": "+33600000000"
        }))

        await ws.send(json.dumps({
            "type": "prompt",
            "voicePrompt": "Réserve un rdv chez le garagiste demain pour faire réparer ma tondeuse à gazon",
            "last": True
        }))

        while True:
            msg = await ws.recv()
            print("recv:", msg)

asyncio.run(main())
'