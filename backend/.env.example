# Copie ce fichier vers `.env` et remplis les valeurs.
# `.env` ne doit JAMAIS être commité (vérifie ton .gitignore).

# --- LLM / API_KEYS ---
MISTRAL_API_KEY=
TAVILY_API_KEY=

# --- TELEGRAM ---
# Tokens créés via @BotFather
TELEGRAM_JS_BOT_TOKEN=
TELEGRAM_VT_BOT_TOKEN=

# Ton chat_id personnel (récupérable via https://api.telegram.org/bot<TOKEN>/getUpdates)
TELEGRAM_CHAT_ID=
